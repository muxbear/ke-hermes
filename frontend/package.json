{
  "name": "ke-hermes-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/motion": "^2.2.6",
    "axios": "^1.7",
    "dagre": "^0.8.5",
    "echarts": "^6.1.0",
    "element-plus": "^2.8",
    "jsencrypt": "^3.3",
    "lucide-vue-next": "^0.400",
    "marked": "^18.0.3",
    "pinia": "^2.2",
    "vue": "^3.5",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^9.14",
    "vue-router": "^4.4"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^5.0",
    "@vue/test-utils": "^2.4",
    "@vue/tsconfig": "^0.7",
    "jsdom": "^24.0",
    "npm-run-all2": "^7.0",
    "prettier": "^3.3",
    "sass": "^1.80",
    "typescript": "~5.5",
    "unplugin-vue-components": "^0.27",
    "vite": "^5.4",
    "vitest": "^2.1",
    "vue-tsc": "^2.1"
  }
}
