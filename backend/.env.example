# DeepSeek LLM 配置
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DashScope 向量模型配置
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING=text-embedding-v4
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 服务配置
HOST=127.0.0.1
PORT=8000

# ---- Workspace ----
WORKSPACE=

# ---- Database ----
DATABASE_BACKEND=postgres # sqlite | postgres
DATABASE_URL=postgresql+psycopg:://<username>:<password>@<ip>:<port>/<db_name>
DATABASE_PATH=sqlite+aiosqlite:///./<db_path>/<db_name>

# ---- CHECKPOINT ----
CHECKPOINT_BACKEND=postgres # sqlite | postgres
CHECKPOINT_DB_URL=postgresql://ip:port/<db_name>
CHECKPOINT_DB_PATH=./<db_path>/<db_name>

# ---- STORE ----
STORE_BACKEND=postgres # sqlite | postgres
STORE_DB_URL=
STORE_DB_PATH=

# ---- JWT ----
JWT_SECRET_KEY=
JWT_ACCESS_EXPIRE=7200
JWT_REFRESH_EXPIRE=604800